<style>
*, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; }
body { font-family:'DM Sans',sans-serif; background:#f9f8f6; color:#1a1a1a; min-height:100vh; }

/* Language toggle */
.lang-toggle { position:fixed; bottom:24px; right:24px; z-index:200; display:flex; background:rgba(255,255,255,0.85); backdrop-filter:blur(12px); border:1px solid rgba(0,0,0,0.08); border-radius:40px; padding:4px; box-shadow:0 4px 20px rgba(0,0,0,0.08); }
.lang-btn { border:none; background:transparent; cursor:pointer; padding:7px 16px; border-radius:32px; font-family:'DM Sans',sans-serif; font-weight:700; font-size:11px; text-transform:uppercase; color:#8a8a8a; transition:all 0.25s; }
.lang-btn.active { background:#cc2828; color:#fff; box-shadow:0 2px 10px rgba(204,40,40,0.3); }
.lang-btn[data-lang="bn"] { font-family:'Noto Sans Bengali',sans-serif; text-transform:none; font-size:12px; }
.lang-en { display:inline; } .lang-bn { display:none; }
body.bn-mode .lang-en { display:none; } body.bn-mode .lang-bn { display:inline; }
.lang-en.block { display:block; } .lang-bn.block { display:none; }
body.bn-mode .lang-bn.block { display:block; } body.bn-mode .lang-en.block { display:none; }
body.bn-mode h1, body.bn-mode h2, body.bn-mode h3, body.bn-mode .eyebrow, body.bn-mode .role-tag, body.bn-mode .project-tag { font-family:'Noto Sans Bengali',sans-serif; text-transform:none; letter-spacing:0; }
body.bn-mode p, body.bn-mode .contributor-name, body.bn-mode .footer-text { font-family:'Noto Sans Bengali',sans-serif; }

/* Header */
.cert-header { background:#fff; border-bottom:1px solid rgba(0,0,0,0.06); padding:18px clamp(20px,5vw,48px); display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; position:sticky; top:0; z-index:100; }
.header-logos { display:flex; align-items:center; gap:14px; }
.header-logos img { height:28px; width:auto; flex-shrink:0; }
.header-logo-sep { width:1px; height:24px; background:rgba(0,0,0,0.12); }
.back-link { display:inline-flex; align-items:center; gap:6px; font-family:'Syne',sans-serif; font-size:11px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:#8a8a8a; text-decoration:none; transition:color 0.2s; }
.back-link:hover { color:#cc2828; }
.back-link svg { transition:transform 0.2s; }
.back-link:hover svg { transform:translateX(-3px); }

/* Hero */
.cert-hero { background:linear-gradient(135deg,rgba(42,39,37,0.93) 0%,rgba(60,50,40,0.92) 100%); color:#e8e4df; padding:clamp(48px,8vh,80px) clamp(20px,5vw,64px); text-align:center; position:relative; overflow:hidden; }
.cert-hero::before { content:'★'; position:absolute; font-size:220px; font-weight:800; opacity:0.03; top:50%; left:50%; transform:translate(-50%,-50%); pointer-events:none; font-family:'Syne',sans-serif; }
.eyebrow { font-family:'Syne',sans-serif; font-size:10px; font-weight:700; letter-spacing:0.25em; text-transform:uppercase; color:rgba(204,40,40,0.8); margin-bottom:14px; }
.cert-hero h1 { font-family:'Syne',sans-serif; font-size:clamp(28px,5vw,52px); font-weight:800; line-height:1.1; letter-spacing:-0.02em; margin-bottom:16px; }
.cert-hero p { font-size:clamp(14px,1.2vw,16px); line-height:1.8; color:rgba(232,228,223,0.72); max-width:560px; margin:0 auto 24px; }
.project-tag { display:inline-flex; align-items:center; gap:6px; padding:6px 16px; border-radius:20px; background:rgba(204,40,40,0.15); border:1px solid rgba(204,40,40,0.25); font-family:'Syne',sans-serif; font-size:10px; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:rgba(232,228,223,0.85); }

/* Main content */
.cert-main { max-width:900px; margin:0 auto; padding:clamp(40px,6vh,72px) clamp(20px,5vw,48px); }

/* Intro box */
.intro-box { background:#fff; border-radius:16px; border:1px solid rgba(0,0,0,0.06); padding:32px; margin-bottom:48px; display:flex; gap:20px; align-items:flex-start; }
.intro-icon { width:44px; height:44px; border-radius:10px; background:rgba(204,40,40,0.08); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.intro-icon svg { color:#cc2828; }
.intro-box h2 { font-family:'Syne',sans-serif; font-size:18px; font-weight:800; margin-bottom:8px; }
.intro-box p { font-size:14px; line-height:1.75; color:#4a4a4a; }
@media(max-width:600px){ .intro-box { flex-direction:column; gap:14px; } }

/* Role sections */
.role-section { margin-bottom:52px; }
.role-header { display:flex; align-items:center; gap:12px; margin-bottom:24px; padding-bottom:14px; border-bottom:2px solid rgba(0,0,0,0.06); }
.role-tag { font-family:'Syne',sans-serif; font-size:9px; font-weight:700; letter-spacing:0.18em; text-transform:uppercase; padding:4px 12px; border-radius:20px; }
.role-tag.pi    { background:rgba(204,40,40,0.08); color:#cc2828; border:1px solid rgba(204,40,40,0.15); }
.role-tag.coord { background:rgba(61,90,128,0.08); color:#3d5a80; border:1px solid rgba(61,90,128,0.15); }
.role-tag.res   { background:rgba(69,123,110,0.08); color:#457b6e; border:1px solid rgba(69,123,110,0.15); }
.role-tag.int   { background:rgba(176,141,64,0.08); color:#8a6d00; border:1px solid rgba(176,141,64,0.15); }
.role-tag.web   { background:rgba(100,80,160,0.08); color:#5a40a0; border:1px solid rgba(100,80,160,0.15); }
.role-tag.sm    { background:rgba(60,140,100,0.08); color:#2a7a50; border:1px solid rgba(60,140,100,0.15); }
.role-section h3 { font-family:'Syne',sans-serif; font-size:16px; font-weight:800; color:#1a1a1a; }

/* Contributor cards */
.contributors-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:16px; }
.contributor-card { background:#fff; border-radius:14px; border:1px solid rgba(0,0,0,0.06); padding:22px 20px; display:flex; align-items:flex-start; gap:14px; transition:all 0.25s; }
.contributor-card:hover { box-shadow:0 8px 28px rgba(0,0,0,0.06); transform:translateY(-2px); }
.contributor-avatar { width:44px; height:44px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Syne',sans-serif; font-size:17px; font-weight:800; color:#fff; flex-shrink:0; }
.contributor-info { flex:1; min-width:0; }
.contributor-name { font-family:'Syne',sans-serif; font-size:15px; font-weight:800; margin-bottom:3px; color:#1a1a1a; }
.contributor-role { font-size:11px; color:#8a8a8a; line-height:1.4; }
.contributor-note { font-size:11px; color:#4a4a4a; margin-top:6px; line-height:1.5; font-style:italic; }

/* For TBA / placeholder */
.contributor-card.tba { opacity:0.5; }
.contributor-card.tba .contributor-name { color:#8a8a8a; }

/* Certificate note */
.cert-note { background:rgba(245,244,242,0.8); border:1px solid rgba(0,0,0,0.06); border-left:3px solid #cc2828; border-radius:0 12px 12px 0; padding:20px 24px; margin-top:48px; }
.cert-note p { font-size:13px; line-height:1.75; color:#4a4a4a; }
.cert-note strong { color:#1a1a1a; }

/* Future projects section */
.future-section { margin-top:56px; padding:36px; background:#fff; border-radius:18px; border:1px solid rgba(0,0,0,0.06); border-top:3px solid #cc2828; text-align:center; }
.future-section h2 { font-family:'Syne',sans-serif; font-size:20px; font-weight:800; margin-bottom:10px; }
.future-section p { font-size:14px; line-height:1.75; color:#4a4a4a; max-width:520px; margin:0 auto 20px; }
.future-tags { display:flex; flex-wrap:wrap; gap:8px; justify-content:center; }
.future-tag { font-size:11px; font-weight:500; padding:5px 14px; border-radius:20px; background:rgba(204,40,40,0.05); border:1px solid rgba(204,40,40,0.1); color:#4a4a4a; }

/* Footer */
.cert-footer { border-top:1px solid rgba(0,0,0,0.06); padding:24px clamp(20px,5vw,48px); text-align:center; }
.footer-text { font-size:12px; color:#8a8a8a; line-height:1.8; }
.footer-text a { color:#cc2828; text-decoration:none; }

/* Stable URL banner */
.url-banner { background:rgba(61,90,128,0.04); border:1px solid rgba(61,90,128,0.12); border-radius:10px; padding:14px 20px; margin-bottom:32px; display:flex; align-items:center; gap:10px; font-size:12px; color:#3d5a80; }
.url-banner code { font-family:monospace; font-size:11px; background:rgba(61,90,128,0.08); padding:2px 7px; border-radius:4px; }

@media(max-width:600px){ .contributors-grid { grid-template-columns:1fr; } .cert-hero { padding:48px 20px; } }
</style>
