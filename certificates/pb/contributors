<script>
(function(){
  var KEY='pb-lang', btnEN=document.getElementById('btnEN'), btnBN=document.getElementById('btnBN');
  var lang = localStorage.getItem(KEY) || 'en';
  function apply(l){
    lang=l; localStorage.setItem(KEY,lang);
    btnEN.classList.toggle('active',lang==='en');
    btnBN.classList.toggle('active',lang==='bn');
    document.body.classList.toggle('bn-mode',lang==='bn');
  }
  btnEN.addEventListener('click',function(){ apply('en'); });
  btnBN.addEventListener('click',function(){ apply('bn'); });
  apply(lang);
})();
</script>
