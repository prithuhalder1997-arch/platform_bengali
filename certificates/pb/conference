    btn.classList.add('active');
    currentFilter = btn.getAttribute('data-filter');
    buildRoster();
  });
});

function normalise(s){ return s.toLowerCase().replace(/\s+/g,' ').trim(); }

function doSearch(){
  var q = document.getElementById('searchInput').value;
  var area = document.getElementById('resultArea');
  if(!q.trim()){ area.innerHTML=''; return; }
  var nq = normalise(q);
  var match = PARTICIPANTS.find(function(p){ return normalise(p.name)===nq || normalise(p.id)===nq; });
  if(!match){
    match = PARTICIPANTS.find(function(p){ return normalise(p.name).indexOf(nq)!==-1 || normalise(p.id).indexOf(nq)!==-1; });
  }
  if(match){
    var body;
    var paperBlock = '<div class="result-paper"><span class="pcode">'+escHtml(match.paper)+'</span><em>'+escHtml(match.title)+'</em>'
      + (match.co ? '<span class="co"><span class="lang-en">With co-author: </span><span class="lang-bn">সহ-লেখক: </span>'+escHtml(match.co)+'</span>' : '')
      + '</div>';

    if(match.status==='withheld'){
      body = '<div class="result-icon absent"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/></svg></div>'
        +'<div>'
        +'<div class="result-name absent-name">'+escHtml(match.name)+'</div>'
        +'<div class="result-id absent-id">'+escHtml(match.id)+'</div>'
        +'<div class="tag-row">'+modeTag(match)+'<span class="tag tag-withheld"><span class="lang-en">No Certificate</span><span class="lang-bn">সার্টিফিকেট নেই</span></span></div>'
        +'<div class="result-meta"><span class="lang-en">'+CONF_EN+'</span><span class="lang-bn">'+CONF_BN+'</span></div>'
        +paperBlock
        +'<p class="absent-notice"><span class="lang-en">This presenter was registered for the conference but was absent and did not submit a recording for the session. In accordance with the criteria above, no certificate has been issued. For queries, write to <a href="mailto:bhashascope@gmail.com" style="color:var(--red);">bhashascope@gmail.com</a>.</span>'
        +'<span class="lang-bn">এই উপস্থাপক সম্মেলনের জন্য নিবন্ধিত ছিলেন কিন্তু অনুপস্থিত ছিলেন এবং অধিবেশনের জন্য কোনো রেকর্ডিং জমা দেননি। উপরোক্ত শর্ত অনুযায়ী কোনো সার্টিফিকেট প্রদান করা হয়নি। প্রশ্নের জন্য লিখুন: <a href="mailto:bhashascope@gmail.com" style="color:var(--red);">bhashascope@gmail.com</a>।</span></p>'
        +'</div>';
    } else {
      var modeEN = match.mode==='offline' ? 'in person' : 'online';
      var modeBN = match.mode==='offline' ? 'সশরীরে' : 'অনলাইনে';
      var confirmText;
      if(match.status==='recording'){
        confirmText = '<p class="confirm-note rec"><span class="lang-en">It is hereby confirmed that this presenter contributed a paper to the <strong>One-Day Hybrid Conference on Bengali in the Digital Economy</strong>, held on 18 July 2026 under the Platform Bengali / Bhashascope project. The presenter\'s recorded presentation was submitted and played at the session; the presenter was not available for the live question-and-answer. A certificate has accordingly been issued on the basis of the recording.</span>'
          +'<span class="lang-bn">এতদ্বারা নিশ্চিত করা হচ্ছে যে এই উপস্থাপক প্ল্যাটফর্ম বেঙ্গলি / ভাষাস্কোপ প্রকল্পের অধীনে ১৮ জুলাই ২০২৬ তারিখে অনুষ্ঠিত <strong>ডিজিটাল অর্থনীতিতে বাংলা বিষয়ক একদিনের হাইব্রিড সম্মেলনে</strong> একটি প্রবন্ধ উপস্থাপন করেছেন। উপস্থাপকের রেকর্ড করা উপস্থাপনাটি জমা দেওয়া হয় এবং অধিবেশনে প্রদর্শিত হয়; উপস্থাপক সরাসরি প্রশ্নোত্তর পর্বে উপস্থিত থাকতে পারেননি। সেই অনুযায়ী রেকর্ডিংয়ের ভিত্তিতে সার্টিফিকেট প্রদান করা হয়েছে।</span></p>';
      } else {
        confirmText = '<p class="confirm-note"><span class="lang-en">It is hereby confirmed that this presenter was present '+modeEN+' at, and presented a paper to, the <strong>One-Day Hybrid Conference on Bengali in the Digital Economy</strong>, held on 18 July 2026 under the Platform Bengali / Bhashascope project.'
          + (match.recording ? ' The presentation was delivered by means of a recorded video played at the session, with the presenter in attendance.' : '')
          + '</span>'
          +'<span class="lang-bn">এতদ্বারা নিশ্চিত করা হচ্ছে যে এই উপস্থাপক প্ল্যাটফর্ম বেঙ্গলি / ভাষাস্কোপ প্রকল্পের অধীনে ১৮ জুলাই ২০২৬ তারিখে অনুষ্ঠিত <strong>ডিজিটাল অর্থনীতিতে বাংলা বিষয়ক একদিনের হাইব্রিড সম্মেলনে</strong> '+modeBN+' উপস্থিত ছিলেন এবং একটি প্রবন্ধ উপস্থাপন করেছেন।'
          + (match.recording ? ' উপস্থাপনাটি অধিবেশনে প্রদর্শিত একটি রেকর্ড করা ভিডিওর মাধ্যমে করা হয়, উপস্থাপক উপস্থিত ছিলেন।' : '')
          + '</span></p>';
      }
      var dlBtn = match.downloadUrl
        ? '<a href="'+match.downloadUrl+'" class="result-dl-btn" download><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M12 3v12M6 15l6 6 6-6"/><path d="M3 19h18"/></svg> <span class="lang-en">Download Certificate</span><span class="lang-bn">সার্টিফিকেট ডাউনলোড করুন</span></a>'
        : confirmText;
      var iconCls = match.status==='recording' ? 'recording' : 'found';
      var iconSvg = match.status==='recording'
        ? '<svg viewBox="0 0 24 24" fill="none" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>'
        : '<svg viewBox="0 0 24 24" fill="none" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22,4 12,14.01 9,11.01"/></svg>';
      body = '<div class="result-icon '+iconCls+'">'+iconSvg+'</div>'
        +'<div>'
        +'<div class="result-name">'+escHtml(match.name)+'</div>'
        +'<div class="result-id">'+escHtml(match.id)+'</div>'
        +'<div class="tag-row">'+modeTag(match)+recTag(match)+'</div>'
        +'<div class="result-meta"><span class="lang-en">'+CONF_EN+'</span><span class="lang-bn">'+CONF_BN+'</span></div>'
        +paperBlock
        +dlBtn
        +'</div>';
    }
    area.innerHTML = '<div style="margin-top:18px;" class="result-card">'+body+'</div>';
    applyLang(currentLang());
  } else {
    area.innerHTML = '<div style="margin-top:18px;" class="result-card">'
      +'<div class="result-icon not-found"><svg viewBox="0 0 24 24" fill="none" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></div>'
      +'<div class="result-not-found-msg"><strong><span class="lang-en">Name not found</span><span class="lang-bn">নাম পাওয়া যায়নি</span></strong><br>'
      +'<span class="lang-en">No record found for "<em>'+escHtml(q)+'</em>". Please check the spelling or write to <a href="mailto:bhashascope@gmail.com" style="color:var(--red);">bhashascope@gmail.com</a>.</span>'
      +'<span class="lang-bn">"<em>'+escHtml(q)+'</em>" নামে কোনো তথ্য পাওয়া যায়নি। বানান পরীক্ষা করুন বা <a href="mailto:bhashascope@gmail.com" style="color:var(--red);">bhashascope@gmail.com</a>-এ যোগাযোগ করুন।</span>'
      +'</div></div>';
    applyLang(currentLang());
  }
}

function onInput(){ if(!document.getElementById('searchInput').value.trim()) document.getElementById('resultArea').innerHTML=''; }
function escHtml(s){ var d=document.createElement('div');d.textContent=s;return d.innerHTML; }

// Bilingual
function currentLang(){ return localStorage.getItem('pb-lang')||'en'; }
function applyLang(l){
  document.body.classList.toggle('bn-mode',l==='bn');
  document.getElementById('mBtnEN').classList.toggle('active',l==='en');
  document.getElementById('mBtnBN').classList.toggle('active',l==='bn');
  localStorage.setItem('pb-lang',l);
}
document.getElementById('mBtnEN').addEventListener('click',function(){applyLang('en');});
document.getElementById('mBtnBN').addEventListener('click',function(){applyLang('bn');});
applyLang(currentLang());

function syncPlaceholder(){
  var inp=document.getElementById('searchInput');
  inp.placeholder=currentLang()==='bn'?'সম্পূর্ণ নাম বা সার্টিফিকেট নম্বর লিখুন…':'Enter full name or certificate number…';
}
document.getElementById('mBtnEN').addEventListener('click',syncPlaceholder);
document.getElementById('mBtnBN').addEventListener('click',syncPlaceholder);
syncPlaceholder();
</script>
