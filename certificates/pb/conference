// Build roster grid
var currentFilter = 'all';
function matchesFilter(p,f){
  if(f==='all') return true;
  if(f==='issued') return p.status!=='withheld';
  if(f==='withheld') return p.status==='withheld';
  if(f==='offline') return p.mode==='offline';
  if(f==='online') return p.mode==='online';
  return true;
}
function buildRoster(){
  var grid = document.getElementById('rosterGrid');
  grid.innerHTML='';
  PARTICIPANTS.filter(function(p){return matchesFilter(p,currentFilter);}).forEach(function(p){
    var item = document.createElement('div');
    var withheld = p.status==='withheld';
    item.className = 'roster-item' + (withheld ? ' absent-row' : '');
    var dot = withheld ? 'absent' : (p.status==='recording' ? 'recording' : 'present');
    item.innerHTML =
      '<span class="roster-dot '+dot+'"></span>'
      +'<span class="roster-name">'+escHtml(p.name)+'</span>'
      +'<span class="roster-mode">'+(p.mode==='offline'?'<span class="lang-en">In-Person</span><span class="lang-bn">সশরীরে</span>':'<span class="lang-en">Online</span><span class="lang-bn">অনলাইন</span>')+'</span>'
      +'<span class="roster-id">'+escHtml(p.id.replace('PB-CONF-2026-','#'))+'</span>';
    grid.appendChild(item);
  });
  applyLang(currentLang());
}
buildRoster();

Array.prototype.forEach.call(document.querySelectorAll('.filter-btn'),function(btn){
