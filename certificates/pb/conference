<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Conference Certificate — Platform Bengali / Bhashascope</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Bengali:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{--red:#cc2828;--dark:#1a1a1a;--mid:#4a4a4a;--light:#f5f4f2;--border:rgba(0,0,0,0.07);--green:#457b6e;--gold:#b08d40;--blue:#3f6d99;}
body{font-family:'DM Sans',sans-serif;background:#faf9f7;color:var(--dark);min-height:100vh;}

/* Header — matches site-header on event pages */
.site-header{position:sticky;top:0;left:0;right:0;z-index:300;display:flex;align-items:center;justify-content:space-between;padding:clamp(8px,1.5vw,16px) clamp(12px,3vw,40px);background:rgba(255,255,255,0.75);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid rgba(0,0,0,0.04);}
.header-logo{display:flex;align-items:center;}
.header-logo .logo-img{height:auto;width:auto;object-fit:contain;}
.header-logo-right .logo-img{height:clamp(40px,6vw,72px);}
.header-logo-left{display:flex;align-items:center;gap:14px;}
.header-logo-left .logo-img{max-height:40px;}
.header-logo-sep{width:1px;height:34px;background:rgba(0,0,0,0.14);display:inline-block;flex-shrink:0;}
.bnp-logo{height:40px;max-height:40px;width:auto;object-fit:contain;}
.monotype-header-logo{height:22px;max-height:22px;width:auto;object-fit:contain;display:block;}
.logo-fallback{font-weight:800;font-size:clamp(10px,1.2vw,14px);letter-spacing:0.1em;text-transform:uppercase;color:var(--dark);}
.header-logo-left .logo-fallback{color:var(--mid);font-weight:700;}
/* Bhashascope logo doubles as home link */
.header-home-link{text-decoration:none;cursor:pointer;transition:opacity 0.2s ease;border-radius:6px;}
.header-home-link:hover{opacity:0.72;}
.header-home-link:focus-visible{outline:2px solid rgba(204,40,40,0.5);outline-offset:3px;}
.header-home-link.header-logo-right{margin-left:0 !important;}

/* Hero band */
.cert-hero{background:linear-gradient(135deg,rgba(42,39,37,0.95) 0%,rgba(60,40,40,0.92) 100%);padding:clamp(40px,7vh,72px) clamp(20px,5vw,64px);text-align:center;}
.cert-hero-eyebrow{font-family:'Syne',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.22em;text-transform:uppercase;color:rgba(204,40,40,0.7);margin-bottom:16px;}
.cert-hero-title{font-family:'Syne',sans-serif;font-size:clamp(26px,4vw,44px);font-weight:800;color:#e8e4df;line-height:1.1;margin-bottom:10px;}
.cert-hero-sub{font-size:clamp(13px,1.1vw,15px);color:rgba(232,228,223,0.55);margin-bottom:24px;line-height:1.6;}
.cert-status-badge{display:inline-flex;align-items:center;gap:7px;padding:8px 18px;border-radius:40px;background:rgba(69,123,110,0.15);border:1px solid rgba(69,123,110,0.35);font-family:'Syne',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#6baa9c;}
.cert-status-dot{width:7px;height:7px;border-radius:50%;background:#6baa9c;}

/* Main container */
.cert-main{max-width:860px;margin:0 auto;padding:clamp(32px,6vh,64px) clamp(20px,5vw,40px);}

/* Stats strip */
.stats-strip{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:32px;}
.stat-box{background:#fff;border:1px solid var(--border);border-radius:12px;padding:16px 14px;text-align:center;}
.stat-num{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;color:var(--dark);line-height:1;margin-bottom:6px;}
.stat-num.green{color:var(--green);} .stat-num.red{color:var(--red);} .stat-num.blue{color:var(--blue);}
.stat-label{font-family:'Syne',sans-serif;font-size:9px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#8a8a8a;line-height:1.4;}

/* Search box */
.search-box{background:#fff;border:1px solid var(--border);border-radius:16px;padding:32px;margin-bottom:32px;box-shadow:0 4px 24px rgba(0,0,0,0.04);}
.search-label{font-family:'Syne',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--mid);margin-bottom:14px;display:block;}
.search-row{display:flex;gap:10px;flex-wrap:wrap;}
.search-input{flex:1;min-width:200px;padding:12px 18px;border:1px solid var(--border);border-radius:10px;font-family:'DM Sans',sans-serif;font-size:15px;color:var(--dark);background:#faf9f7;outline:none;transition:border-color 0.2s;}
.search-input:focus{border-color:var(--red);box-shadow:0 0 0 3px rgba(204,40,40,0.08);}
.search-input::placeholder{color:#b0a8a0;}
.search-btn{padding:12px 24px;border-radius:10px;border:none;background:var(--red);color:#fff;font-family:'Syne',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;transition:all 0.2s;white-space:nowrap;}
.search-btn:hover{background:#b02020;transform:translateY(-1px);box-shadow:0 6px 18px rgba(204,40,40,0.25);}
.search-hint{margin-top:10px;font-size:12px;color:#8a8a8a;font-style:italic;}

/* Result area */
.result-area{min-height:60px;}
.result-card{background:#fff;border:1px solid var(--border);border-radius:14px;padding:24px 28px;display:flex;align-items:flex-start;gap:18px;animation:fadeUp 0.4s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}
.result-icon{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;}
.result-icon.found{background:rgba(69,123,110,0.1);}
.result-icon.recording{background:rgba(176,141,64,0.12);}
.result-icon.absent{background:rgba(0,0,0,0.05);}
.result-icon.not-found{background:rgba(204,40,40,0.07);}
.result-icon svg{width:22px;height:22px;}
.result-icon.found svg{stroke:var(--green);}
.result-icon.recording svg{stroke:var(--gold);}
.result-icon.absent svg{stroke:#a0a0a0;}
.result-icon.not-found svg{stroke:var(--red);}
.result-name{font-family:'Syne',sans-serif;font-size:18px;font-weight:800;color:var(--dark);margin-bottom:6px;}
.result-name.absent-name{color:#a0a0a0;}
.result-meta{font-size:13px;color:var(--mid);margin-bottom:14px;line-height:1.5;}
.result-id{display:inline-block;font-family:'DM Sans',sans-serif;font-size:11px;font-weight:700;letter-spacing:0.08em;padding:3px 10px;border-radius:8px;background:rgba(69,123,110,0.07);border:1px solid rgba(69,123,110,0.15);color:var(--green);margin-bottom:12px;}
.result-id.absent-id{background:rgba(0,0,0,0.04);border-color:rgba(0,0,0,0.1);color:#a0a0a0;}
.result-paper{font-size:13px;color:var(--mid);line-height:1.6;margin-bottom:12px;padding-left:12px;border-left:2px solid var(--border);}
.result-paper .pcode{font-family:'Syne',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.1em;color:#b0a8a0;display:block;margin-bottom:3px;}
.result-paper em{color:var(--dark);font-style:italic;}
.result-paper .co{display:block;margin-top:5px;font-size:12px;color:#8a8a8a;}
.result-dl-btn{display:inline-flex;align-items:center;gap:7px;padding:10px 20px;border-radius:10px;background:var(--dark);color:#fff;font-family:'Syne',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;transition:all 0.2s;}
.result-dl-btn:hover{background:var(--red);transform:translateY(-1px);box-shadow:0 6px 16px rgba(0,0,0,0.15);}
.result-dl-btn svg{width:14px;height:14px;stroke:currentColor;}
.result-not-found-msg{font-size:14px;color:var(--mid);line-height:1.6;}
.result-not-found-msg strong{color:var(--dark);}
.absent-notice{font-size:13px;color:#a0a0a0;line-height:1.6;font-style:italic;}
.confirm-note{font-size:13px;color:var(--mid);line-height:1.75;margin-top:2px;border-left:3px solid var(--green);padding-left:14px;}
.confirm-note.rec{border-left-color:var(--gold);}

/* Tags */
.tag{display:inline-flex;align-items:center;gap:5px;font-family:'Syne',sans-serif;font-size:9px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:3px 9px;border-radius:20px;white-space:nowrap;}
.tag-offline{background:rgba(63,109,153,0.1);color:var(--blue);border:1px solid rgba(63,109,153,0.2);}
.tag-online{background:rgba(69,123,110,0.1);color:var(--green);border:1px solid rgba(69,123,110,0.2);}
.tag-rec{background:rgba(176,141,64,0.12);color:var(--gold);border:1px solid rgba(176,141,64,0.25);}
.tag-withheld{background:rgba(0,0,0,0.05);color:#a0a0a0;border:1px solid rgba(0,0,0,0.08);}
.tag-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;}

/* Participant roster */
.roster-section{margin-bottom:40px;}
.section-title{font-family:'Syne',sans-serif;font-size:12px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#8a8a8a;margin-bottom:16px;display:flex;align-items:center;gap:10px;}
.section-title::after{content:'';flex:1;height:1px;background:var(--border);}
.roster-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:8px;}
.roster-item{background:#fff;border:1px solid var(--border);border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:10px;transition:box-shadow 0.2s;}
.roster-item:hover{box-shadow:0 3px 12px rgba(0,0,0,0.06);}
.roster-item.absent-row{background:#f7f6f5;border-color:rgba(0,0,0,0.05);opacity:0.6;}
.roster-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.roster-dot.present{background:var(--green);}
.roster-dot.recording{background:var(--gold);}
.roster-dot.absent{background:#c8c4c0;}
.roster-name{font-size:13px;font-weight:500;color:var(--dark);line-height:1.3;flex:1;}
.roster-item.absent-row .roster-name{color:#a0a0a0;}
.roster-mode{font-family:'Syne',sans-serif;font-size:9px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#b0a8a0;}
.roster-id{font-family:'DM Sans',sans-serif;font-size:10px;font-weight:700;color:#b0a8a0;letter-spacing:0.03em;}
.roster-legend{display:flex;align-items:center;gap:18px;margin-bottom:14px;font-size:12px;color:#8a8a8a;flex-wrap:wrap;}
.roster-legend-item{display:flex;align-items:center;gap:6px;}

/* Filter tabs */
.filter-row{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;}
.filter-btn{padding:7px 16px;border-radius:30px;border:1px solid var(--border);background:#fff;font-family:'Syne',sans-serif;font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#8a8a8a;cursor:pointer;transition:all 0.2s;}
.filter-btn:hover{border-color:rgba(204,40,40,0.3);color:var(--red);}
.filter-btn.active{background:var(--dark);border-color:var(--dark);color:#fff;}

/* Info section */
.info-section{margin-top:40px;margin-bottom:40px;}
.info-title{font-family:'Syne',sans-serif;font-size:12px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#8a8a8a;margin-bottom:20px;}
.info-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px;}
.info-card{background:#fff;border:1px solid var(--border);border-radius:12px;padding:18px 20px;}
.info-card-label{font-family:'Syne',sans-serif;font-size:9px;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#8a8a8a;margin-bottom:5px;}
.info-card-val{font-size:14px;font-weight:500;color:var(--dark);line-height:1.4;}

/* Criteria */
.criteria-section{margin-top:40px;margin-bottom:40px;}
.criteria-box{background:#fff;border:1px solid var(--border);border-radius:14px;padding:24px 28px;}
.criteria-list{list-style:none;}
.criteria-list li{font-size:13.5px;color:var(--mid);line-height:1.7;padding-left:26px;position:relative;margin-bottom:12px;}
.criteria-list li:last-child{margin-bottom:0;}
.criteria-list li::before{content:'';position:absolute;left:0;top:8px;width:8px;height:8px;border-radius:50%;background:var(--green);}
.criteria-list li.no::before{background:#c8c4c0;}
.criteria-list li strong{color:var(--dark);font-weight:600;}

/* Group photo */
.group-photo-section{margin-top:40px;margin-bottom:40px;}
.group-photo-wrap{border-radius:16px;overflow:hidden;border:1px solid var(--border);box-shadow:0 8px 32px rgba(0,0,0,0.08);}
.group-photo-wrap img{width:100%;height:auto;display:block;}
.group-photo-caption{background:#fff;border-top:1px solid var(--border);padding:16px 20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;}
.group-photo-caption-text{font-size:13px;color:var(--mid);line-height:1.5;}
.group-photo-caption-text strong{color:var(--dark);font-weight:600;}

/* Footer */
.cert-footer{border-top:1px solid var(--border);padding:24px clamp(20px,5vw,48px);text-align:center;font-size:12px;color:#8a8a8a;line-height:1.7;}
.cert-footer a{color:var(--red);text-decoration:none;}
.cert-footer a:hover{text-decoration:underline;}

/* Bilingual */
.lang-en{display:inline;} .lang-bn{display:none;}
body.bn-mode .lang-en{display:none;} body.bn-mode .lang-bn{display:inline;}
.lang-en.block,.lang-bn.block{display:block;}
body.bn-mode .lang-en.block{display:none;} body.bn-mode .lang-bn.block{display:block;}
body.bn-mode .cert-hero-title,.cert-hero-eyebrow,.search-label,.result-name,.info-card-label{font-family:'Noto Sans Bengali',sans-serif;}
body.bn-mode .cert-hero-sub,.result-meta,.result-not-found-msg,.search-hint,.info-card-val{font-family:'Noto Sans Bengali',sans-serif;}

/* Lang toggle */
.lang-mini{position:fixed;bottom:24px;right:24px;display:flex;background:rgba(255,255,255,0.9);backdrop-filter:blur(12px);border:1px solid rgba(0,0,0,0.08);border-radius:40px;padding:3px;box-shadow:0 4px 16px rgba(0,0,0,0.07);z-index:200;}
.lang-mini button{border:none;background:transparent;cursor:pointer;padding:6px 14px;border-radius:30px;font-family:'DM Sans',sans-serif;font-weight:700;font-size:11px;text-transform:uppercase;color:#8a8a8a;transition:all 0.25s;}
.lang-mini button.active{background:var(--red);color:#fff;}
.lang-mini button[data-lang="bn"]{font-family:'Noto Sans Bengali',sans-serif;text-transform:none;font-size:12px;}

@media(max-width:600px){.search-row{flex-direction:column;}.search-btn{width:100%;}.cert-hero{padding:36px 20px;}.result-card{flex-direction:column;gap:12px;}.roster-grid{grid-template-columns:1fr;}.stats-strip{grid-template-columns:1fr 1fr;}
.header-logo-left{margin-left:auto;}.header-logo-left .logo-img{max-height:30px;}.bnp-logo{height:30px;}.header-logo-sep{height:26px;}.monotype-header-logo{height:17px;}.header-logo-right .logo-img{height:clamp(32px,7vw,44px);}}
</style>
</head>
<body>

<!-- Header — matches event pages -->
<header class="site-header" id="siteHeader">
  <!-- Left: Bhashascope — site brand, links home -->
  <a href="../../index.html" class="header-logo header-logo-right header-home-link" aria-label="Bhashascope — go to homepage"><img src="../../img/Bhashascope_logo.png" alt="Bhashascope" class="logo-img" onerror="this.style.display='none';this.nextElementSibling.style.display='block';"><span class="logo-fallback" style="display:none;">Bhashascope</span></a>
  <!-- Right: supporter logos -->
  <div class="header-logo header-logo-left">
    <img src="../../img/ifa-logo.png" alt="IFA" class="logo-img" onerror="this.style.display='none';this.nextElementSibling.style.display='block';"><span class="logo-fallback" style="display:none;">IFA</span>
    <span class="header-logo-sep"></span>
    <img src="../../img/BNPP_Logo.png" alt="BNP Paribas" class="logo-img bnp-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='block';"><span class="logo-fallback" style="display:none;">BNP Paribas</span>
    <span class="header-logo-sep"></span>
    <picture>
      <source srcset="../../img/Monotype_Black_Logo.webp" type="image/webp">
      <img src="../../img/Monotype_Black_Logo.png" alt="Monotype" class="logo-img monotype-header-logo" onerror="var p=this.closest('picture'); if(p){ p.style.display='none'; var f=p.nextElementSibling; if(f) f.style.display='block'; }">
    </picture><span class="logo-fallback" style="display:none;">Monotype</span>
  </div>
</header>

<!-- Hero -->
<div class="cert-hero">
  <div class="cert-hero-eyebrow">
    <span class="lang-en">Platform Bengali / Bhashascope · Certificate Registry</span>
    <span class="lang-bn">প্ল্যাটফর্ম বেঙ্গলি / ভাষাস্কোপ · সার্টিফিকেট রেজিস্ট্রি</span>
  </div>
  <div class="cert-hero-title">
    <span class="lang-en">One-Day Hybrid Conference</span>
    <span class="lang-bn">একদিনের হাইব্রিড সম্মেলন</span>
  </div>
  <div class="cert-hero-sub">
    <span class="lang-en">Bengali in the Digital Economy · 18 July 2026<br>Held in hybrid mode — in-person and online</span>
    <span class="lang-bn">ডিজিটাল অর্থনীতিতে বাংলা · ১৮ জুলাই ২০২৬<br>হাইব্রিড পদ্ধতিতে অনুষ্ঠিত — সশরীরে ও অনলাইনে</span>
  </div>
  <span class="cert-status-badge">
    <span class="cert-status-dot"></span>
    <span class="lang-en">Certificates Issued</span><span class="lang-bn">সার্টিফিকেট প্রদান সম্পন্ন</span>
  </span>
</div>

<!-- Main -->
<main class="cert-main">

  <!-- Stats -->
  <div class="stats-strip">
    <div class="stat-box">
      <div class="stat-num">42</div>
      <div class="stat-label"><span class="lang-en">Registered<br>Presenters</span><span class="lang-bn">নিবন্ধিত<br>উপস্থাপক</span></div>
    </div>
    <div class="stat-box">
      <div class="stat-num green">36</div>
      <div class="stat-label"><span class="lang-en">Certificates<br>Issued</span><span class="lang-bn">প্রদত্ত<br>সার্টিফিকেট</span></div>
    </div>
    <div class="stat-box">
      <div class="stat-num blue">16</div>
      <div class="stat-label"><span class="lang-en">Issued<br>In-Person</span><span class="lang-bn">সশরীরে<br>প্রদত্ত</span></div>
    </div>
    <div class="stat-box">
      <div class="stat-num blue">20</div>
      <div class="stat-label"><span class="lang-en">Issued<br>Online</span><span class="lang-bn">অনলাইনে<br>প্রদত্ত</span></div>
    </div>
    <div class="stat-box">
      <div class="stat-num red">6</div>
      <div class="stat-label"><span class="lang-en">Certificates<br>Withheld</span><span class="lang-bn">স্থগিত<br>সার্টিফিকেট</span></div>
    </div>
  </div>

  <!-- Search box -->
  <div class="search-box">
    <span class="search-label">
      <span class="lang-en">Verify your certificate</span>
      <span class="lang-bn">আপনার সার্টিফিকেট যাচাই করুন</span>
    </span>
    <div class="search-row">
      <input class="search-input" type="text" id="searchInput"
        placeholder="Enter full name or certificate number…"
        oninput="onInput()"
        onkeydown="if(event.key==='Enter')doSearch()">
      <button class="search-btn" onclick="doSearch()">
        <span class="lang-en">Search</span><span class="lang-bn">খুঁজুন</span>
      </button>
    </div>
    <p class="search-hint">
      <span class="lang-en">Enter the name exactly as it appears on your certificate, or your certificate number (e.g. PB-CONF-2026-001).</span>
      <span class="lang-bn">সার্টিফিকেটে যেভাবে নাম আছে সেইভাবে লিখুন, অথবা সার্টিফিকেট নম্বর দিন (যেমন PB-CONF-2026-001)।</span>
    </p>
    <div class="result-area" id="resultArea"></div>
  </div>

  <!-- Participant Roster -->
  <div class="roster-section">
    <p class="section-title">
      <span class="lang-en">Presenters (42)</span>
      <span class="lang-bn">উপস্থাপক (৪২)</span>
